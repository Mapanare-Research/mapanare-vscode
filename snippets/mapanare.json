{
  "Function": {
    "prefix": "fn",
    "body": [
      "fn ${1:name}(${2:params}) -> ${3:ReturnType} {",
      "    ${0}",
      "}"
    ],
    "description": "Define a Mapanare function"
  },
  "Public Function": {
    "prefix": "pubfn",
    "body": [
      "pub fn ${1:name}(${2:params}) -> ${3:ReturnType} {",
      "    ${0}",
      "}"
    ],
    "description": "Define a public Mapanare function"
  },
  "Main Function": {
    "prefix": "main",
    "body": [
      "fn main() {",
      "    ${0}",
      "}"
    ],
    "description": "Define the main entry point"
  },
  "Agent": {
    "prefix": "agent",
    "body": [
      "agent ${1:Name} {",
      "    input ${2:msg}: ${3:String}",
      "    output ${4:result}: ${5:String}",
      "",
      "    fn handle(${2:msg}: ${3:String}) -> ${5:String} {",
      "        ${0}",
      "    }",
      "}"
    ],
    "description": "Define a Mapanare agent"
  },
  "Public Agent": {
    "prefix": "pubagent",
    "body": [
      "pub agent ${1:Name} {",
      "    input ${2:msg}: ${3:String}",
      "    output ${4:result}: ${5:String}",
      "",
      "    fn handle(${2:msg}: ${3:String}) -> ${5:String} {",
      "        ${0}",
      "    }",
      "}"
    ],
    "description": "Define a public Mapanare agent"
  },
  "Pipe": {
    "prefix": "pipe",
    "body": [
      "pipe ${1:Name} {",
      "    ${2:stage1} |> ${3:stage2}",
      "}"
    ],
    "description": "Define a Mapanare pipe"
  },
  "Struct": {
    "prefix": "struct",
    "body": [
      "struct ${1:Name} {",
      "    ${2:field}: ${3:Type}",
      "}"
    ],
    "description": "Define a Mapanare struct"
  },
  "Enum": {
    "prefix": "enum",
    "body": [
      "enum ${1:Name} {",
      "    ${2:Variant1},",
      "    ${3:Variant2}",
      "}"
    ],
    "description": "Define a Mapanare enum"
  },
  "Let Binding": {
    "prefix": "let",
    "body": [
      "let ${1:name}: ${2:Type} = ${0}"
    ],
    "description": "Declare an immutable binding"
  },
  "Mutable Let Binding": {
    "prefix": "letmut",
    "body": [
      "let mut ${1:name}: ${2:Type} = ${0}"
    ],
    "description": "Declare a mutable binding"
  },
  "If Expression": {
    "prefix": "if",
    "body": [
      "if ${1:condition} {",
      "    ${0}",
      "}"
    ],
    "description": "If expression"
  },
  "If-Else Expression": {
    "prefix": "ifelse",
    "body": [
      "if ${1:condition} {",
      "    ${2}",
      "} else {",
      "    ${0}",
      "}"
    ],
    "description": "If-else expression"
  },
  "Match Expression": {
    "prefix": "match",
    "body": [
      "match ${1:expr} {",
      "    ${2:pattern} => ${3:body},",
      "    _ => ${0}",
      "}"
    ],
    "description": "Match expression"
  },
  "For Loop": {
    "prefix": "for",
    "body": [
      "for ${1:item} in ${2:iterable} {",
      "    ${0}",
      "}"
    ],
    "description": "For-in loop"
  },
  "Spawn Agent": {
    "prefix": "spawn",
    "body": [
      "let ${1:handle} = spawn ${2:AgentName}()"
    ],
    "description": "Spawn an agent"
  },
  "Signal": {
    "prefix": "signal",
    "body": [
      "let ${1:name} = signal(${0})"
    ],
    "description": "Create a signal"
  },
  "Computed Signal": {
    "prefix": "signalc",
    "body": [
      "let ${1:name} = signal {",
      "    ${0}",
      "}"
    ],
    "description": "Create a computed signal"
  },
  "Import": {
    "prefix": "import",
    "body": [
      "import ${1:module}::${0}"
    ],
    "description": "Import a module"
  },
  "Impl Block": {
    "prefix": "impl",
    "body": [
      "impl ${1:TypeName} {",
      "    fn ${2:method}(${3:params}) -> ${4:ReturnType} {",
      "        ${0}",
      "    }",
      "}"
    ],
    "description": "Implement methods for a type"
  }
}
