{
  "Function": {
    "prefix": "fn",
    "body": [
      "fn ${1:name}(${2:params}) -> ${3:ReturnType} {",
      "    ${0}",
      "}"
    ],
    "description": "Define a Mapanare function"
  },
  "Public Function": {
    "prefix": "pubfn",
    "body": [
      "pub fn ${1:name}(${2:params}) -> ${3:ReturnType} {",
      "    ${0}",
      "}"
    ],
    "description": "Define a public Mapanare function"
  },
  "Main Function": {
    "prefix": "main",
    "body": [
      "fn main() {",
      "    ${0}",
      "}"
    ],
    "description": "Define the main entry point"
  },
  "Agent": {
    "prefix": "agent",
    "body": [
      "agent ${1:Name} {",
      "    input ${2:msg}: ${3:String}",
      "    output ${4:result}: ${5:String}",
      "",
      "    fn handle(${2:msg}: ${3:String}) -> ${5:String} {",
      "        ${0}",
      "    }",
      "}"
    ],
    "description": "Define a Mapanare agent"
  },
  "Public Agent": {
    "prefix": "pubagent",
    "body": [
      "pub agent ${1:Name} {",
      "    input ${2:msg}: ${3:String}",
      "    output ${4:result}: ${5:String}",
      "",
      "    fn handle(${2:msg}: ${3:String}) -> ${5:String} {",
      "        ${0}",
      "    }",
      "}"
    ],
    "description": "Define a public Mapanare agent"
  },
  "Pipe": {
    "prefix": "pipe",
    "body": [
      "pipe ${1:Name} {",
      "    ${2:stage1} |> ${3:stage2}",
      "}"
    ],
    "description": "Define a Mapanare pipe"
  },
  "Struct": {
    "prefix": "struct",
    "body": [
      "struct ${1:Name} {",
      "    ${2:field}: ${3:Type}",
      "}"
    ],
    "description": "Define a Mapanare struct"
  },
  "Enum": {
    "prefix": "enum",
    "body": [
      "enum ${1:Name} {",
      "    ${2:Variant1},",
      "    ${3:Variant2}",
      "}"
    ],
    "description": "Define a Mapanare enum"
  },
  "Trait": {
    "prefix": "trait",
    "body": [
      "trait ${1:Name} {",
      "    fn ${2:method}(self${3:, params}) -> ${4:ReturnType}",
      "}"
    ],
    "description": "Define a trait"
  },
  "Impl Block": {
    "prefix": "impl",
    "body": [
      "impl ${1:TypeName} {",
      "    fn ${2:method}(self${3:, params}) -> ${4:ReturnType} {",
      "        ${0}",
      "    }",
      "}"
    ],
    "description": "Implement methods for a type"
  },
  "Impl Trait": {
    "prefix": "implfor",
    "body": [
      "impl ${1:TraitName} for ${2:TypeName} {",
      "    fn ${3:method}(self${4:, params}) -> ${5:ReturnType} {",
      "        ${0}",
      "    }",
      "}"
    ],
    "description": "Implement a trait for a type"
  },
  "Extern Function": {
    "prefix": "extern",
    "body": [
      "extern \"${1:C}\" fn ${2:name}(${3:params}) -> ${4:ReturnType}"
    ],
    "description": "Declare an external (FFI) function"
  },
  "Let Binding": {
    "prefix": "let",
    "body": [
      "let ${1:name}: ${2:Type} = ${0}"
    ],
    "description": "Declare an immutable binding"
  },
  "Mutable Let Binding": {
    "prefix": "letmut",
    "body": [
      "let mut ${1:name}: ${2:Type} = ${0}"
    ],
    "description": "Declare a mutable binding"
  },
  "If Expression": {
    "prefix": "if",
    "body": [
      "if ${1:condition} {",
      "    ${0}",
      "}"
    ],
    "description": "If expression"
  },
  "If-Else Expression": {
    "prefix": "ifelse",
    "body": [
      "if ${1:condition} {",
      "    ${2}",
      "} else {",
      "    ${0}",
      "}"
    ],
    "description": "If-else expression"
  },
  "Match Expression": {
    "prefix": "match",
    "body": [
      "match ${1:expr} {",
      "    ${2:pattern} => ${3:body},",
      "    _ => ${0}",
      "}"
    ],
    "description": "Match expression"
  },
  "For Loop": {
    "prefix": "for",
    "body": [
      "for ${1:item} in ${2:iterable} {",
      "    ${0}",
      "}"
    ],
    "description": "For-in loop"
  },
  "While Loop": {
    "prefix": "while",
    "body": [
      "while ${1:condition} {",
      "    ${0}",
      "}"
    ],
    "description": "While loop"
  },
  "Spawn Agent": {
    "prefix": "spawn",
    "body": [
      "let ${1:handle} = spawn ${2:AgentName}()"
    ],
    "description": "Spawn an agent"
  },
  "Signal": {
    "prefix": "signal",
    "body": [
      "let ${1:name} = signal(${0})"
    ],
    "description": "Create a signal"
  },
  "Computed Signal": {
    "prefix": "signalc",
    "body": [
      "let ${1:name} = signal {",
      "    ${0}",
      "}"
    ],
    "description": "Create a computed signal"
  },
  "Stream": {
    "prefix": "stream",
    "body": [
      "let ${1:name} = stream(${0})"
    ],
    "description": "Create a stream"
  },
  "Import": {
    "prefix": "import",
    "body": [
      "import ${1:module}::${0}"
    ],
    "description": "Import a module"
  },
  "Import With Items": {
    "prefix": "importi",
    "body": [
      "import ${1:module} { ${0} }"
    ],
    "description": "Import specific items from a module"
  },
  "New Struct": {
    "prefix": "new",
    "body": [
      "new ${1:StructName} {",
      "    ${2:field}: ${0}",
      "}"
    ],
    "description": "Construct a struct instance"
  },
  "GPU Function": {
    "prefix": "gpu",
    "body": [
      "@gpu",
      "fn ${1:name}(${2:params}) -> ${3:ReturnType} {",
      "    ${0}",
      "}"
    ],
    "description": "Define a GPU-dispatched function"
  },
  "CUDA Function": {
    "prefix": "cuda",
    "body": [
      "@cuda",
      "fn ${1:name}(${2:params}) -> ${3:ReturnType} {",
      "    ${0}",
      "}"
    ],
    "description": "Define a CUDA-dispatched function"
  },
  "Tensor": {
    "prefix": "tensor",
    "body": [
      "let ${1:name}: Tensor<${2:Float}>[${3:rows}, ${4:cols}] = ${0}"
    ],
    "description": "Declare a tensor"
  },
  "Map Literal": {
    "prefix": "map",
    "body": [
      "#{${1:key}: ${2:value}, ${0}}"
    ],
    "description": "Create a map literal"
  },
  "Result Ok": {
    "prefix": "ok",
    "body": [
      "Ok(${0})"
    ],
    "description": "Wrap value in Ok"
  },
  "Result Err": {
    "prefix": "err",
    "body": [
      "Err(${0})"
    ],
    "description": "Wrap value in Err"
  },
  "Option Some": {
    "prefix": "some",
    "body": [
      "Some(${0})"
    ],
    "description": "Wrap value in Some"
  },
  "Assert": {
    "prefix": "assert",
    "body": [
      "assert ${1:condition}, \"${0}\""
    ],
    "description": "Assert with message"
  },
  "Export": {
    "prefix": "export",
    "body": [
      "export ${0}"
    ],
    "description": "Export a definition"
  },
  "Type Alias": {
    "prefix": "type",
    "body": [
      "type ${1:Name} = ${0}"
    ],
    "description": "Define a type alias"
  }
}
